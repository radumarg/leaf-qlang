                    "SWAP(q0, q1);"
                    "SWAP(q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/rxx.lf"
                    "RXX(1, q0, q1);"
                    "RXX(1, q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/ryy.lf"
                    "RYY(1, q0, q1);"
                    "RYY(1, q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/rzz.lf"
                    "RZZ(1, q0, q1);"
                    "RZZ(1, q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/ccx.lf"
                    "CCX(q0, q1, q2);"
                    "CCX(q0, q1, q2);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/cswap.lf"
                    "CSWAP(q0, q1, q2);"
                    "CSWAP(q0, q1, q2);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/gpi.lf"
                    "GPI(1, q);"
                    "GPI(1, q);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/gpi2.lf"
                    "GPI2(1, q);"
                    "GPI2(1, q);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/ms.lf"
                    "MS(1, 2, q0, q1);"
                    "MS(1, 2, q0, q1);"
                    
    -- Test quantum gates declarations corner cases
    runParseOkTest "src/Test/Fixtures/Good/Gates/noSpacesSingleQubitGate.lf"
                    "H(q);"
                    "H(q);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/extraWhitespaceSingleQubitGate.lf"
                    "SDG(q);"
                    "SDG(q);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/noSpacesTwoQubitGate.lf"
                    "CX(q0, q1);"
                    "CX(q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/extraWhitespaceTwoQubitGate.lf"
                    "SWAP(q0, q1);"
                    "SWAP(q0, q1);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/noSpacesParametricGate.lf"
                    "RX(1, q);"
                    "RX(1, q);"
    runParseOkTest "src/Test/Fixtures/Good/Gates/extraWhitespaceParametricGate.lf"
                    "CU3(1, 2, 3, q0, q1);"
                    "CU3(1, 2, 3, q0, q1);"

    -- Test invalid quantum gates declarations
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingClosingParenInSingleQubitGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingArgumentSeparatorInSingleQubitGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingCommaInTwoQubitGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingClosingParenInTwoQubitGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingCommaInParametricGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingMiddleParameterInParametricGate.lf"
    runParseShouldFailTest
                    "src/Test/Fixtures/Bad/Gates/missingClosingParenInParametricGate.lf"