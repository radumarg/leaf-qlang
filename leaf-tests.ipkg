          Frontend.Lexer,
          Frontend.Parser,
          Frontend.Token,
          Frontend.ExprPrettyPrinter,
          Test.TestsHelper,
          Test.TypeParseTests,
          Test.ArraysParseTests,
          Test.Run

main = Test.Run
executable = leaf-tests